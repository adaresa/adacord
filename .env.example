DISCORD_TOKEN=your-discord-bot-token

# Optional: set this for instant slash-command updates in one server.
DISCORD_GUILD_ID=

LOG_LEVEL=INFO
MESSAGE_DELETE_AFTER=5
DEFAULT_VOLUME=50

# Must match lavalink/application.yml and docker-compose.yml.
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_URI=http://lavalink:2333
PLAYER_IDLE_TIMEOUT=30
VOICE_CONNECT_TIMEOUT=30

# Optional: helps Lavalink play YouTube tracks from VPS/datacenter IPs when
# YouTube asks clients to sign in. Use a burner Google/YouTube account.
YOUTUBE_OAUTH_ENABLED=false
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_OAUTH_SKIP_INITIALIZATION=true
YOUTUBE_CIPHER_PASSWORD=choose-a-cipher-password
